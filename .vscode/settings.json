{
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "tsconfig.json, *.config.mjs, *.config.ts, pnpm-lock.yaml, pnpm-workspace.yaml, .npmrc, .nvmrc, skills-lock.json",
        "README.md": "AGENTS.md",
        ".gitignore": ".gitmodules, .gitattributes"
    }
}
