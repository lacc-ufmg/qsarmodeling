{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ui:dev",
      "type": "shell",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}/apps/desktop"
      },
      "command": "pnpm",
      "args": [
        "dev"
      ]
    },
    {
      "label": "ui:build",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/apps/desktop"
      },
      "command": "pnpm",
      "args": [
        "run",
        "vitebuild"
      ]
    }
  ]
}
