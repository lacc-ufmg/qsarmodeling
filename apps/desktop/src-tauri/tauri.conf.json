{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qsarmodeling",
  "version": "0.0.1",
  "identifier": "com.hellmrf.qsarmodeling",
  "build": {
    "beforeDevCommand": "pnpm sync-sidecar && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm sync-sidecar",
    "frontendDist": "../../frontend/out"
  },
  "app": {
    "windows": [
      {
        "title": "QSAR Modeling 2.0",
        "width": 1200,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/qsar-backend"
    ]
  }
}
