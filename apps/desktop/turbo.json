{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["frontend#build", "sync-sidecar"],
      "inputs": ["$TURBO_DEFAULT$", "src-tauri/**"],
      "outputs": ["src-tauri/target/release/**", "$TURBO_ROOT$/target/release/**"],
      "cache": true
    },
    "sync-sidecar": {
      "dependsOn": ["backend#build"],
      "inputs": ["$TURBO_DEFAULT$", "scripts/sync-backend-sidecar.mjs"],
      "outputs": ["src-tauri/binaries/qsar-backend*"],
      "cache": true
    }
  }
}
