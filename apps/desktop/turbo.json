{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      // "dependsOn": ["prebuild"],
      "inputs": ["$TURBO_DEFAULT$", "src-tauri/**", "src/**", "public/**", "vite.config.ts", "tauri.conf.json"],
      "outputs": ["$TURBO_ROOT$/target/release/bundle/**"],
      "cache": true
    },
    "sync-sidecar": {
      "dependsOn": ["backend#build"],
      "inputs": ["$TURBO_DEFAULT$", "scripts/sync-backend-sidecar.mjs"],
      "outputs": ["src-tauri/binaries/qsar-backend*"],
      "cache": true
    },
    "prebuild": {
      // "dependsOn": ["vitebuild", "sync-sidecar"],
      "dependsOn": ["vitebuild"],
      "cache": true
    },
    "vitebuild": {
      "inputs": ["$TURBO_DEFAULT$", "vite.config.ts", "src/**/*", "public/**/*", "index.html"],
      "outputs": ["dist/**"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true,
      // "with": ["backend#dev"]
    }
  }
}
