{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "package.json", "*.config.mjs", "*.config.ts", "tsconfig.json", "src/**", "public/**"],
      "outputs": [".next/**", "out/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "with": ["backend#dev"]
    }
  }
}
